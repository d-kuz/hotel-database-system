Процедура заселения 

CREATE OR REPLACE PROCEDURE check_in (
    code_r    IN room.code_room%TYPE,
    code_p    IN person.code_person%TYPE,
    date_out  IN residents.date_check_out%TYPE,
    date_in   IN residents.date_check_in%TYPE,
    n_people  IN NUMBER,
    err       OUT VARCHAR2
)
AS
    p_sex VARCHAR(10);
    cap   NUMBER;
BEGIN
    -- Определение вместимости номера
    SELECT capacity_category INTO cap
    FROM room
    JOIN categories USING (code_category)
    WHERE code_room = code_r;

    err := 'Выполнено заселение';

    -- Заселение одного человека
    IF n_people = 1 THEN
        IF (free_places(code_r) > 0) AND (check_status(code_r, code_p) = 1) THEN
            SELECT sex INTO p_sex
            FROM person
            WHERE code_person = code_p;

            -- Если после заселения мест не осталось — номер занят
            IF (free_places(code_r) = 1) AND (cap >= 1) THEN
                UPDATE room SET code_status = 1  -- 'Занят'
                WHERE code_room = code_r;
            END IF;

            -- Если номер полностью свободен и заселяется женщина
            IF (free_places(code_r) = cap) AND (p_sex = 'Ж') THEN
                UPDATE room SET code_status = 3  -- 'Свободен для женщин'
                WHERE code_room = code_r;
            END IF;

            -- Если номер полностью свободен и заселяется мужчина
            IF (free_places(code_r) = cap) AND (p_sex = 'М') THEN
                UPDATE room SET code_status = 4  -- 'Свободен для мужчин'
                WHERE code_room = code_r;
            END IF;

            INSERT INTO residents (date_check_out, date_check_in, code_room, code_person)
            VALUES (date_out, date_in, code_r, code_p);
        ELSE
            err := 'Не удалось выполнить заселение';
        END IF;
    END IF;

    -- Заселение семьи (более одного человека)
    IF n_people > 1 THEN
        IF (free_places(code_r) = cap) AND (n_people <= cap) THEN
            UPDATE room SET code_status = 1  -- 'Занят'
            WHERE code_room = code_r;

            INSERT INTO residents (date_check_out, date_check_in, code_room, code_person)
            VALUES (date_out, date_in, code_r, code_p);
        ELSE
            err := 'Не удалось выполнить заселение';
        END IF;
    END IF;
END check_in;
